{
  "name": "uniform_mutation_single_construct_gc_constraint",
  "description": "Generate a single DNA sequence with uniform mutation and GC content constraint",
  "version": "1.0",
  "optimization": {
      "method": "mcmc",
      "steps": 100,
      "track_step_size": 5,
      "temperature": 2.0
  },
  "constructs": [
    {
      "id": "construct1",
      "type": "dna",    

      "segments": [
        {
          "id": "construct1-segment1"
        }
      ]
    },
    {
      "id": "construct2",
      "type": "dna",

      "segments": [
        {
          "id": "construct2-segment1"
        }
      ]
    }    
  ],
  "constraints": [
    {
      "id": "gc_content_constraint",
      "key": "gc-content",
      "config": {
        "min_gc": 95,
        "max_gc": 100
      },
      "targets": ["construct1-segment1"]
    },
    {
      "id": "gc_content_constrain2t",
      "key": "gc-content",
      "config": {
        "min_gc": 0,
        "max_gc": 1
      },
      "targets": ["construct2-segment1"]
    }    
  ],
  "generators": [
    {
      "id": "uniform_mutation_generator",
      "key": "uniform-mutation",
      "config": {
        "mutation_rate": 0.01,
        "batch_size": 1,
        "sequence_length": 20
      },
      "targets": ["construct1-segment1"]
    },
    {
      "id": "uniform_mutation_generator2",
      "key": "uniform-mutation",
      "config": {
        "mutation_rate": 0.01,
        "batch_size": 1,
        "sequence_length": 20
      },
      "targets": ["construct2-segment1"]
    }    
  ]
}
