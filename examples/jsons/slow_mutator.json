{
  "name": "slow_test_program",
  "description": "A slow-running test program for async API testing",
  "version": "1.0",
  "optimization": {
    "method": "mcmc",
    "num_selected": 1,
    "mcmc_width": 1,
    "num_steps": 20,
    "track_step_size": 2,
    "max_temperature": 2.0,
    "min_temperature": 0.1
  },
  "constructs": [
    {
      "id": "test_construct1",
      "type": "dna",
      "segments": [
        {
          "id": "segment1",
          "label": "test_sequence"
        }
      ]
    }
  ],
  "constraints": [
    {
      "id": "gc_content_constraint",
      "key": "gc-content",
      "label": "High GC Content",
      "config": {
        "min_gc": 95,
        "max_gc": 100
      },
      "targets": ["segment1"]
    }
  ],
  "generators": [
    {
      "id": "slow_mutation",
      "key": "uniform-mutation",
      "config": {
        "sequence_length": 15,
        "debug_with_sleep_calls": true
      },
      "targets": ["segment1"]
    }
  ]
}
