{
  "name": "evo2_single_construct_gc_constraint",
  "description": "Generate a single DNA sequence with Evo2 generator and GC content constraint",
  "version": "1.0",
  "constructs": [
    {
      "id": "construct1",
      "type": "dna",
      "segments": [
        {
          "id": "construct1-segment1",
          "length": 100
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "evo2",
          "config": {
            "prompts": [
              "ATCG"
            ],
            "model_checkpoint": "evo2_7b",
            "temperature": 0.8,
            "prepend_prompt": true
          },
          "target": "construct1-segment1"
        }
      ],
      "constraints": [
        {
          "key": "gc-content",
          "config": {
            "min_gc": 90,
            "max_gc": 100
          },
          "targets": [
            "construct1-segment1"
          ]
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_selected": 1,
          "num_steps": 10,
          "track_step_size": 1,
          "max_temperature": 1.0
        }
      }
    }
  ]
}