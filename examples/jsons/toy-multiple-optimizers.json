{
  "name": "multi_stage_gc_optimization",
  "description": "Two-stage optimization: TopK for broad exploration, then MCMC for fine-tuning",
  "version": "1.0",
  "constructs": [
    {
      "type": "DNA",
      "segments": [
        {
          "id": "seq1",
          "label": "seq1",
          "length": 20
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "random-nucleotide",
          "target": "seq1",
          "config": {
            "masking_strategy": { "num_mutations": 10 }
          }
        }
      ],
      "constraints": [
        {
          "key": "gc-content",
          "targets": [
            "seq1"
          ],
          "config": {
            "min_gc": 50,
            "max_gc": 100
          }
        }
      ],
      "optimizer": {
        "method": "topk",
        "config": {
          "num_samples": 10,
          "num_results": 3,
          "samples_per_round": 2,
          "verbose": true
        }
      }
    },
    {
      "generators": [
        {
          "key": "random-nucleotide",
          "target": "seq1",
          "config": {
            "masking_strategy": { "num_mutations": 1 }
          }
        }
      ],
      "constraints": [
        {
          "key": "gc-content",
          "targets": [
            "seq1"
          ],
          "config": {
            "min_gc": 80,
            "max_gc": 90
          }
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_results": 1,
          "num_steps": 10,
          "max_temperature": 2.0
        }
      }
    }
  ]
}
