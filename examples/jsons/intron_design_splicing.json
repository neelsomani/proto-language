{
  "name": "intron_design_splicing",
  "description": "Slim teaching version of the intron-design pipeline: optimize a 297 bp variable intron embedded between fixed left/right flanks (a working AAV-style expression cassette: GFP coding context upstream, BGH polyA context downstream) so the spliced mRNA has high splicing efficiency in BRAIN tissue and low splicing efficiency in BLOOD. The constraint set is `splice-transformer-intron-boundary` (penalize cryptic splice sites inside the intron and reward the canonical donor at position 348 / acceptor at position 650), `splice-transformer-specificity` with tissue=BRAIN direction=max (activate the splice site in brain), and `splice-transformer-specificity` with tissue=BLOOD direction=min (silence the splice site in blood). All three constraints share the same 4 kb left/right plasmid context (CMV-driven cassette in pcDNA backbone, matching `intron_design_alphagenome.json`). For a more thorough version that scores the same intron across three plasmid contexts (CMV / EF1a / SFFV) and four genomic safe-harbor sites (AAVS1 / CCR5 / CLYBL / hROSA26) with AlphaGenome, see `intron_design_alphagenome.json`. SpliceTransformer reference: Zeng & Bromberg 2024; tissue indices follow the SpliceTransformer GTEx tissue list.",
  "version": "1.0",
  "num_results": 1,
  "constructs": [
    {
      "id": "intron_construct",
      "type": "dna",
      "label": "Intron in CMV expression cassette",
      "segments": [
        {
          "id": "left_flank",
          "label": "Left flank (eGFP CDS context)",
          "sequence": ""
        },
        {
          "id": "intron",
          "label": "Variable 297 bp intron core",
          "sequence": "AGTTTAAGAGGGAATAACGCCCCCCTCTCTATCAGATACTGCCTTGTGTAACACCCTAGCCCACTTGGACAGGCTGCTCATAACTGGAACCTAACATAGCCAACATACTTATGACAACTCGGACGTCCCGAAGAGAACAGTCGTGGAATATAAATAACCCCGGGATCACAACCTAACTTCTTCACTCCGAGATTAACTGAAGGGACTCATTGGCCTCTACAGCGATATATTCGCTGACCCGCCGGCCACCCGTGTTCCATCTGAAGTGTACCCCGGACAGGTACACAGTTCAGTTTC"
        },
        {
          "id": "right_flank",
          "label": "Right flank (BGH poly(A) signal context)",
          "sequence": ""
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "random-nucleotide",
          "targets": ["intron"],
          "config": {
            "masking_strategy": {
              "method": "random",
              "num_mutations": 1,
              "temperature": 1
            },
            "substitution_scheme": "N"
          }
        }
      ],
      "constraints": [
        {
          "key": "splice-transformer-intron-boundary",
          "label": "splice_boundary",
          "targets": [
            "left_flank",
            "intron",
            "right_flank"
          ],
          "config": {
            "left_context": "",
            "right_context": "",
            "donor_pos": [
              348
            ],
            "acceptor_pos": [
              650
            ]
          }
        },
        {
          "key": "splice-transformer-specificity",
          "label": "splice_specificity_brain_max",
          "targets": [
            "left_flank",
            "intron",
            "right_flank"
          ],
          "config": {
            "left_context": "",
            "right_context": "",
            "splice_pos": [
              348,
              650
            ],
            "tissue": "BRAIN",
            "direction": "max"
          }
        },
        {
          "key": "splice-transformer-specificity",
          "label": "splice_specificity_blood_min",
          "targets": [
            "left_flank",
            "intron",
            "right_flank"
          ],
          "config": {
            "left_context": "",
            "right_context": "",
            "splice_pos": [
              348,
              650
            ],
            "tissue": "BLOOD",
            "direction": "min"
          }
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_steps": 500,
          "max_temperature": 1.0,
          "min_temperature": 0.001,
          "temperature_schedule": "exponential",
          "proposals_per_result": 1,
          "tracking_interval": 1,
          "track_proposals": false,
          "verbose": true
        }
      }
    }
  ]
}
