{
  "name": "phage_mmseqs_gcs",
  "description": "Test out mmseqs with GCS database",
  "version": "1.0",
  "constructs": [
    {
      "id": "phage_genome",
      "type": "dna",
      "segments": [
        {
          "id": "test_segment",
          "length": 20
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "random-nucleotide",
          "config": {
            "masking_strategy": { "num_mutations": 1 }
          },
          "target": "test_segment"
        }
      ],
      "constraints": [
        {
          "key": "mmseqs-gene-homology",
          "config": {
            "min_homology": 50.0,
            "max_homology": 90.0,
            "mmseqs_db": "gcs://evo-design/phrogs_mmseqs_db",
            "orf_predictor": "orfipy",
            "orfipy_config": {
              "output_dir": "",
              "min_len": 30,
              "max_len": 1000,
              "start_codons": [
                "ATG"
              ],
              "stop_codons": [
                "TAA",
                "TAG",
                "TGA"
              ]
            },
            "mmseqs_config": {
              "results_dir": "",
              "threads": 4,
              "sensitivity": 4.0
            }
          },
          "targets": [
            "test_segment"
          ]
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_results": 1,
          "num_steps": 50,
          "max_temperature": 2.0
        }
      }
    }
  ]
}
