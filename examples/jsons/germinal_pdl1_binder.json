          }
        }
      ],
      "constraints": [
        {
          "key": "af2-binder",
          "label": "af2",
          "targets": ["binder", "pdl1_target"],
          "config": {
            "target_pdb": "examples/data/pd_l1_5ius.pdb",
            "target_chains": ["B"],
