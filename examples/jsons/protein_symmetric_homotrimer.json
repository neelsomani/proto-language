{
  "name": "protein_symmetric_homotrimer",
  "description": "Symmetric homotrimer design matching `examples/scripts/program_symmetric_proteins.py` with three 50 aa protein protomer constructs and 3000 MCMC steps. A single shared `random-protein` generator targets all three protomer segments with one mutation per proposal, tying their proposed sequences so the optimizer designs one monomer sequence replicated across a three-chain complex. The ESMFold confidence constraints, ring-symmetry constraint, and globularity constraint score the three protomers together as the symmetric assembly.",
  "version": "1.0",
  "num_results": 1,
  "constructs": [
    {
      "id": "protomer_construct_1",
      "type": "protein",
      "label": "protomer_1",
      "segments": [
        {
          "id": "protomer_1",
          "label": "protomer_1",
          "length": 50
        }
      ]
    },
    {
      "id": "protomer_construct_2",
      "type": "protein",
      "label": "protomer_2",
      "segments": [
        {
          "id": "protomer_2",
          "label": "protomer_2",
          "length": 50
        }
      ]
    },
    {
      "id": "protomer_construct_3",
      "type": "protein",
      "label": "protomer_3",
      "segments": [
        {
          "id": "protomer_3",
          "label": "protomer_3",
          "length": 50
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "random-protein",
          "label": "shared protomer generator",
          "targets": ["protomer_1", "protomer_2", "protomer_3"],
          "config": {
            "masking_strategy": {
              "num_mutations": 1
            }
          }
        }
      ],
      "constraints": [
        {
          "key": "structure-plddt",
          "targets": ["protomer_1", "protomer_2", "protomer_3"],
          "weight": 1,
          "config": { "structure_tool": "esmfold" }
        },
        {
          "key": "structure-ptm",
          "targets": ["protomer_1", "protomer_2", "protomer_3"],
          "weight": 1,
          "config": { "structure_tool": "esmfold" }
        },
        {
          "key": "protein-symmetry-ring",
          "targets": ["protomer_1", "protomer_2", "protomer_3"],
          "weight": 1,
          "config": {
            "all_to_all_protomer_symmetry": true
          }
        },
        {
          "key": "protein-globularity",
          "targets": ["protomer_1", "protomer_2", "protomer_3"],
          "weight": 5,
          "config": {}
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_steps": 3000,
          "max_temperature": 1.0,
          "min_temperature": 0.0001,
          "verbose": true
        }
      }
    }
  ]
}
