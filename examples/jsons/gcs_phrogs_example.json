{
  "name": "phage_mmseqs_gcs",
  "description": "Test out mmseqs with GCS database",
  "version": "1.0",  
  "optimization": {
      "method": "mcmc",
      "num_selected": 1,
      "mcmc_width": 1,
      "num_steps": 50,
      "track_step_size": 5,
      "max_temperature": 2.0
  },
  "constructs": [
    {
      "id": "phage_genome",
      "type": "dna",
      "segments": [
        {
          "id": "test_segment",
          "sequence_length": 20
        }
      ]
    }
  ],
  "constraints": [
    {
      "id": "mmseqs_homology_constraint",
      "key": "mmseqs-gene-homology",
      "config": {
        "min_homology": 50.0,
        "max_homology": 90.0,
        "mmseqs_db": "gcs://evo-design/phrogs_mmseqs_db",
        "orf_predictor": "orfipy",
        "orfipy_config": {
          "output_dir": "",
          "min_len": 30,
          "max_len": 1000,
          "start_codons": ["ATG"],
          "stop_codons": ["TAA", "TAG", "TGA"]
        },
        "mmseqs_config": {
          "results_dir": "",
          "threads": 4,
          "sensitivity": 4.0
        }
      },
      "targets": ["test_segment"]
    }
  ],
  "generators": [
    {
      "id": "uniform_mutation_generator",
      "key": "uniform-mutation",
      "config": {
        "num_mutations": 1
      },
      "targets": ["test_segment"]
    }
  ]
}