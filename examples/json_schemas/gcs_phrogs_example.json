{
  "name": "phage_mmseqs_gcs",
  "description": "Test out mmseqs with GCS database",
  "version": "1.0",  
  "optimization": {
      "method": "mcmc",
      "num_steps": 50,
      "track_step_size": 5,
      "temperature": 2.0
  },
  "constructs": [
    {
      "id": "phage_genome",
      "type": "dna",
      "segments": [
        {
          "id": "test_segment"
        }
      ]
    }
  ],
  "constraints": [
    {
      "id": "orfipy_mmseqs_constraint",
      "key": "orfipy-mmseqs-gene-hit-count",
      "config": {
        "min_hits": 1,
        "max_hits": 10,
        "orfipy_kwargs": {
          "min_len": 30,
          "max_len": 1000,
          "start_codons": "ATG",
          "stop_codons": "TAA,TAG,TGA"
        },
        "mmseqs_kwargs": {
          "database": "gcs://evo-design/phrogs_mmseqs_db",
          "threads": 4,
          "sensitivity": 4.0,
          "only_top_hits": true
        }
      },
      "targets": ["test_segment"]
    }
  ],
  "generators": [
    {
      "id": "uniform_mutation_generator",
      "key": "uniform-mutation",
      "config": {
        "mutation_rate": 0.01,
        "batch_size": 1,
        "sequence_length": 20
      },
      "targets": ["test_segment"]
    }
  ]
}