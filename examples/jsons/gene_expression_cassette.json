{
  "name": "gene_expression_cassette",
  "description": "Design bacterial expression cassette with promoter, gene, and terminator",
  "version": "1.0",
  "constructs": [
    {
      "id": "expression_construct",
      "type": "dna",
      "segments": [
        {
          "id": "promoter",
          "label": "sigma70_promoter",
          "length": 50
        },
        {
          "id": "gene",
          "label": "coding_sequence",
          "length": 300
        },
        {
          "id": "terminator",
          "label": "transcriptional_terminator",
          "length": 50
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "random-nucleotide",
          "config": {
            "masking_strategy": { "num_mutations": 2 }
          },
          "target": "promoter"
        },
        {
          "key": "random-nucleotide",
          "config": {
            "masking_strategy": { "num_mutations": 3 }
          },
          "target": "gene"
        },
        {
          "key": "random-nucleotide",
          "config": {
            "masking_strategy": { "num_mutations": 2 }
          },
          "target": "terminator"
        }
      ],
      "constraints": [
        {
          "key": "sigma70-promoter",
          "config": {
            "consensus_35": "TTGACA",
            "consensus_10": "TATAAT",
            "optimal_spacer": 17
          },
          "targets": [
            "promoter"
          ]
        },
        {
          "key": "gc-content",
          "config": {
            "min_gc": 30.0,
            "max_gc": 50.0
          },
          "targets": [
            "promoter"
          ]
        },
        {
          "key": "gc-content",
          "config": {
            "min_gc": 40.0,
            "max_gc": 60.0
          },
          "targets": [
            "gene"
          ]
        },
        {
          "key": "sequence-length",
          "config": {
            "target_length": 300
          },
          "targets": [
            "gene"
          ]
        },
        {
          "key": "sequence-length",
          "config": {
            "target_length": 50
          },
          "targets": [
            "promoter"
          ]
        },
        {
          "key": "sequence-length",
          "config": {
            "target_length": 50
          },
          "targets": [
            "terminator"
          ]
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_results": 1,
          "num_steps": 200,
          "max_temperature": 2.0,
          "min_temperature": 0.001
        }
      }
    }
  ]
}
