{
  "name": "toy",
  "description": "Smoke test: generate a 100 bp DNA segment with balanced GC content (40-60%) and no long homopolymers, using random nucleotide mutation under MCMC. Used as the canonical fast end-to-end example to verify the registry, parser, optimizer, and result wiring without invoking GPU tools or external services. Targets the GC range typical of E. coli K-12 coding sequences (~50% GC; Hershberg & Petrov 2008) so the optimizer's solution is biologically reasonable rather than a single homopolymer of G/C.",
  "version": "1.0",
  "num_results": 1,
  "constructs": [
    {
      "id": "construct1",
      "type": "dna",
      "segments": [
        {
          "id": "variable_dna",
          "label": "100 bp variable DNA",
          "length": 100
        }
      ]
    }
  ],
  "optimization_stages": [
    {
      "generators": [
        {
          "key": "random-nucleotide",
          "targets": ["variable_dna"],
          "config": {
            "masking_strategy": {
              "method": "random",
              "num_mutations": 2,
              "temperature": 1
            },
            "substitution_scheme": "N"
          }
        }
      ],
      "constraints": [
        {
          "key": "gc-content",
          "targets": ["variable_dna"],
          "config": {
            "min_gc": 40.0,
            "max_gc": 60.0
          }
        },
        {
          "key": "max-homopolymer",
          "targets": ["variable_dna"],
          "config": {
            "max_length": 5
          }
        }
      ],
      "optimizer": {
        "method": "mcmc",
        "config": {
          "num_steps": 100,
          "max_temperature": 1.0,
          "min_temperature": 0.01,
          "temperature_schedule": "exponential",
          "proposals_per_result": 1,
          "tracking_interval": 1,
          "track_proposals": false,
          "verbose": false
        }
      }
    }
  ]
}
